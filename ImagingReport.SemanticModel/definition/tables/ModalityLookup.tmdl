/// Modality code to name mapping via DAX SWITCH
/// In Direct Lake mode, this is a calculated table using DATATABLE
table ModalityLookup
	lineageTag: 55555555-5555-5555-5555-555555555555

	column ModalityCode
		dataType: string
		lineageTag: a5000001-0000-0000-0000-000000000001
		summarizeBy: none
		isNameInferred
		sourceColumn: [ModalityCode]

		annotation SummarizationSetBy = Automatic

	column ModalityName
		dataType: string
		lineageTag: a5000002-0000-0000-0000-000000000002
		summarizeBy: none
		isNameInferred
		sourceColumn: [ModalityName]

		annotation SummarizationSetBy = Automatic

	partition ModalityLookup = calculated
		source =
				DATATABLE(
				    "ModalityCode", STRING,
				    "ModalityName", STRING,
				    {
				        {"CT", "Computed Tomography"},
				        {"MR", "Magnetic Resonance (MRI)"},
				        {"MG", "Mammography"},
				        {"CR", "Computed Radiography"},
				        {"NM", "Nuclear Medicine"},
				        {"PT", "Positron Emission Tomography (PET)"},
				        {"OP", "Ophthalmic Photography"},
				        {"OPT", "Ophthalmic Tomography (OCT)"},
				        {"XC", "External-camera Photography"},
				        {"US", "Ultrasound"},
				        {"XA", "X-Ray Angiography"},
				        {"DX", "Digital Radiography"},
				        {"SC", "Secondary Capture"},
				        {"RF", "Radiofluoroscopy"},
				        {"IO", "Intra-Oral Radiography"}
				    }
				)

	annotation PBI_Id = 55555555555555555555555555555555

